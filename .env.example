# Required
DISCORD_TOKEN=your_discord_bot_token

# MongoDB (required for watchlist / waifu / reminder features)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/myFirstDatabase?retryWrites=true&w=majority
MONGODB_URI_WAIFUS=mongodb+srv://user:password@cluster.mongodb.net/myFirstDatabase?retryWrites=true&w=majority

# Reddit (optional — meme/reddit commands)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=stella-discord-bot

# Selenium / anime update checker (optional — requires Chrome/Chromium installed)
CHROME_BINARY_PATH=
CHROMEDRIVER_PATH=

# Bot owner Discord user ID (optional)
BOT_OWNER_ID=745006368175423489

# Startup channel ID for "Hello Master" message (optional — leave empty to skip)
STARTUP_CHANNEL_ID=
